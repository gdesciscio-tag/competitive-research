# Copy this file to `.env` and fill in the values. `.env` is gitignored — never commit secrets.
# Each key is only needed for the steps that use it; you can fill them in incrementally.

# --- Claude API (topical map + draft post steps) ---
# Get a key at https://console.anthropic.com -> API keys.
ANTHROPIC_API_KEY=

# --- DataForSEO (keyword step, "api" mode only) ---
# Sign up at https://dataforseo.com; use your account login email + password (or an API password).
# Not needed if you use --keyword-source manual (KeySearch CSVs).
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# --- Google Sheets (sheet step) ---
# Absolute path to a Google Cloud service-account JSON key (Sheets API + Drive API enabled).
GOOGLE_SERVICE_ACCOUNT_JSON=
# The Google account that each created Sheet is shared with (appears in its "Shared with me").
GOOGLE_SHARE_EMAIL=
